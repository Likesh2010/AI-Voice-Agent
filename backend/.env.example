# Example environment variables for local development.
# Copy to .env and fill with your secrets. DO NOT commit .env.

OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_RESPONSE_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_STT_MODEL=whisper-1

# Twilio (fill if you plan to make real calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Publicly reachable base URL for Twilio webhooks (ngrok or your domain)
PUBLIC_BASE_URL=http://localhost:8000

DATABASE_URL=sqlite:///./voice_recruitment.db
